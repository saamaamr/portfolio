{
  "name": "abdullah-al-mamun-portfolio",
  "version": "1.0.0",
  "description": "Personal portfolio website for Abdullah Al Mamun built with Node.js, Express, HTML, CSS, and JavaScript.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "fuser -k 3000/tcp 2>/dev/null; nodemon --delay 2.5 app.js & npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "dev:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "dev:kill": "fuser -k 3000/tcp 2>/dev/null; nodemon --delay 2.5 app.js",
    "vercel-build": "npm run build:css",
    "generate-pdf": "node scripts/generate-pdf.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "portfolio",
    "express",
    "node",
    "personal website"
  ],
  "author": "Abdullah Al Mamun",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.9",
    "email-validator": "^2.0.4",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "gsap": "^3.15.0",
    "helmet": "^7.1.0",
    "nodemailer": "^8.0.7",
    "winston": "^3.11.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "puppeteer-core": "^24.43.0",
    "supertest": "^6.3.3",
    "tailwindcss": "^4.2.4"
  }
}
